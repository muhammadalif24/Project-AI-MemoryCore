{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "project-plugins": {
      "source": {
        "source": "directory",
        "path": "plugins"
      }
    }
  },
  "enabledPlugins": {
    "matt-skills@project-plugins": true
  }
}
